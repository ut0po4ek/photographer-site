---
const reviews = [
  {
    name: 'Анастасия С.',
    type: 'Портретная съёмка',
    text: 'Анна, огромное спасибо за вашу работу. Очень классные фотографии получились. Вы мастер своего дела! Обязательно с вами поработаем.',
  },
  {
    name: 'Елена В.',
    type: 'Love Story',
    text: 'Очень понравилась атмосфера и результат. Всё спокойно, красиво и без лишней постановки.',
  },
  {
    name: 'Ирина и Сергей',
    type: 'Семейная съёмка',
    text: 'Получили фотографии быстрее, чем ожидали. Теперь это наши любимые семейные кадры.',
  },
];
---

<section id="reviews" class="section-light section-padding">
  <div class="container-site">

    <h2
      class="mb-14 md:mb-20"
      style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 300; letter-spacing: -0.01em;"
    >
      Отзывы моих клиентов
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <div
          class="review-card flex flex-col gap-5 p-7"
          style="background: var(--color-bg-warm); border: 1px solid var(--color-border);"
        >
          <!-- Quote -->
          <div
            aria-hidden="true"
            style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 3.5rem; line-height: 1; color: var(--color-border); font-weight: 300; margin-bottom: -0.5rem;"
          >"</div>

          <p class="text-sm leading-relaxed flex-1" style="color: var(--color-fg-muted);">
            {review.text}
          </p>

          <div class="pt-5" style="border-top: 1px solid var(--color-border);">
            <p class="text-sm font-medium" style="color: var(--color-fg);">{review.name}</p>
            <p
              class="text-xs mt-1"
              style="color: var(--color-fg-subtle); letter-spacing: 0.08em; text-transform: uppercase;"
            >{review.type}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
