---
import { siteConfig } from '../../config/site';
---

<section
  id="hero"
  class="section-dark relative overflow-hidden"
  style="min-height: 100svh; min-height: 100vh;"
  aria-label="Главный экран"
>
  <!-- Full-screen background photo -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=1600&q=80"
      alt=""
      class="w-full h-full object-cover object-center"
      style="filter: grayscale(1) brightness(0.42);"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(17,17,17,0.92) 0%, rgba(17,17,17,0.45) 50%, rgba(17,17,17,0.20) 100%);"
    ></div>
  </div>

  <!-- Content: vertically centered, left-aligned -->
  <div class="container-site relative z-10 flex flex-col justify-end" style="min-height: 100svh; min-height: 100vh; padding-bottom: 6rem; padding-top: 7rem;">
    <div class="max-w-2xl">

      <!-- Photographer name — large serif -->
      <h1
        class="mb-3"
        style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(3.5rem, 9vw, 8rem); font-weight: 300; line-height: 0.95; letter-spacing: -0.01em; color: #f4f4f0;"
      >
        Анна<br />Смирнова
      </h1>

      <!-- PHOTOGRAPHER label -->
      <p
        class="mb-8"
        style="font-size: 0.75rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(244,244,240,0.60);"
      >
        PHOTOGRAPHER
      </p>

      <!-- Divider -->
      <div class="mb-8" style="width: 3rem; height: 1px; background: rgba(244,244,240,0.30);"></div>

      <!-- Stats row -->
      <div class="flex flex-wrap gap-x-10 gap-y-3 mb-10">
        <div style="border-left: 1px solid rgba(244,244,240,0.25); padding-left: 1rem;">
          <p style="font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.10em; text-transform: uppercase; color: rgba(244,244,240,0.45); line-height: 1.5;">более 6 лет<br />опыта в съёмке</p>
        </div>
        <div style="border-left: 1px solid rgba(244,244,240,0.25); padding-left: 1rem;">
          <p style="font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.10em; text-transform: uppercase; color: rgba(244,244,240,0.45); line-height: 1.5;">победитель<br />локальных конкурсов</p>
        </div>
      </div>

      <!-- CTA button -->
      <a
        href={siteConfig.cta.href}
        class="hero-cta-btn inline-flex items-center justify-center px-8 py-3.5 text-xs font-medium tracking-[0.18em] uppercase"
        style="border: 1px solid rgba(244,244,240,0.50); color: #f4f4f0; letter-spacing: 0.18em;"
      >
        Записаться на съёмку
      </a>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 right-8 flex flex-col items-center gap-3 z-10"
    aria-hidden="true"
    style="opacity: 0.30;"
  >
    <span style="writing-mode: vertical-lr; font-size: 0.5rem; font-weight: 500; letter-spacing: 0.20em; text-transform: uppercase; color: #f4f4f0;">scroll</span>
    <div style="width: 1px; height: 2.5rem; background: #f4f4f0;"></div>
  </div>
</section>

<style>
  .hero-cta-btn {
    transition: background-color 250ms ease, border-color 250ms ease;
  }
  .hero-cta-btn:hover {
    background-color: rgba(244, 244, 240, 0.10);
    border-color: rgba(244, 244, 240, 0.85);
  }
</style>
