---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../config/site';
---

<section
  id="hero"
  class="hero-section section-adaptive-light relative min-h-screen flex flex-col overflow-hidden"
  aria-label="Главный экран"
>
  <!-- ── Background composition ── z-index 0–4 ──────── -->
  <div class="hero-bg absolute inset-0 overflow-hidden" aria-hidden="true">

    <!-- Right-side toned panel — z 1 -->
    <div
      class="hero-panel absolute right-0 top-0 w-[48%] h-full"
      style="background: var(--hero-panel-bg); clip-path: polygon(8% 0, 100% 0, 100% 100%, 0% 100%); z-index: 1;"
    ></div>

    <!-- Vertical split line — z 1 -->
    <div class="hero-vline absolute left-[52%] top-0 w-px h-full" style="background: var(--hero-line); opacity: 0.55; z-index: 1;"></div>

    <!-- Horizontal registration line — z 1 -->
    <div class="hero-hline absolute top-[32%] h-px" style="left: 8%; right: 48%; background: var(--hero-line); z-index: 1;"></div>

    <!-- ── Architectural drawing — z 4, pinned to RIGHT half only ── -->
    <!-- left edge = 50% of viewport, so it never reaches into the text zone -->
    <div class="hero-drawing absolute" style="left: 50%; right: 0; top: 8%; bottom: 8%; pointer-events: none; z-index: 4;">

      <!-- Floor plan outline — main room -->
      <svg
        class="hero-plan"
        viewBox="0 0 420 520"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        style="position:absolute; inset:0; width:100%; height:100%; opacity: var(--hero-drawing-opacity);"
      >
        <!-- Outer wall -->
        <rect x="32" y="28" width="356" height="464" stroke="var(--hero-draw-stroke)" stroke-width="1.5"/>

        <!-- Inner room dividers -->
        <line x1="32" y1="200" x2="220" y2="200" stroke="var(--hero-draw-stroke)" stroke-width="1"/>
        <line x1="220" y1="28" x2="220" y2="310" stroke="var(--hero-draw-stroke)" stroke-width="1"/>
        <line x1="220" y1="340" x2="220" y2="492" stroke="var(--hero-draw-stroke)" stroke-width="1"/>
        <line x1="220" y1="200" x2="388" y2="200" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.75"/>

        <!-- Door swing (living room) -->
        <path d="M32 200 Q68 200 68 236" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.75" stroke-dasharray="2 3"/>
        <line x1="32" y1="200" x2="32" y2="236" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.75"/>

        <!-- Window openings -->
        <line x1="120" y1="28" x2="200" y2="28" stroke="var(--hero-draw-accent)" stroke-width="2.5"/>
        <line x1="280" y1="28" x2="360" y2="28" stroke="var(--hero-draw-accent)" stroke-width="2.5"/>
        <line x1="388" y1="120" x2="388" y2="200" stroke="var(--hero-draw-accent)" stroke-width="2.5"/>

        <!-- Dimension ticks and leaders — top -->
        <line x1="32" y1="14" x2="388" y2="14" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>
        <line x1="32" y1="10" x2="32" y2="18" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>
        <line x1="388" y1="10" x2="388" y2="18" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>

        <!-- Dimension ticks — right -->
        <line x1="402" y1="28" x2="402" y2="492" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>
        <line x1="398" y1="28" x2="406" y2="28" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>
        <line x1="398" y1="492" x2="406" y2="492" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>

        <!-- Interior furnishing hints — living area -->
        <rect x="50" y="220" width="80" height="50" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5" stroke-dasharray="3 2"/>
        <rect x="145" y="220" width="55" height="50" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5" stroke-dasharray="3 2"/>
        <rect x="50" y="155" width="150" height="36" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5" stroke-dasharray="3 2"/>

        <!-- Interior furnishing hints — bedroom -->
        <rect x="240" y="48" width="130" height="90" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5" stroke-dasharray="3 2"/>
        <rect x="240" y="220" width="130" height="80" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5" stroke-dasharray="3 2"/>

        <!-- North indicator -->
        <line x1="390" y1="460" x2="390" y2="440" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <polygon points="390,436 386,446 390,443 394,446" fill="var(--hero-draw-accent)"/>

        <!-- Label: ПЛАН -->
        <text x="36" y="9" font-size="5" font-family="'Inter', sans-serif" letter-spacing="0.12em" text-transform="uppercase" fill="var(--hero-draw-label)">ПЛАН · 1:100</text>

        <!-- Label: room tags -->
        <text x="100" y="126" font-size="5.5" font-family="'Inter', sans-serif" letter-spacing="0.1em" fill="var(--hero-draw-label)" text-anchor="middle">ГОСТИНАЯ</text>
        <text x="310" y="100" font-size="5.5" font-family="'Inter', sans-serif" letter-spacing="0.1em" fill="var(--hero-draw-label)" text-anchor="middle">СПАЛЬНЯ</text>
        <text x="100" y="390" font-size="5.5" font-family="'Inter', sans-serif" letter-spacing="0.1em" fill="var(--hero-draw-label)" text-anchor="middle">КУХНЯ</text>
        <text x="310" y="390" font-size="5.5" font-family="'Inter', sans-serif" letter-spacing="0.1em" fill="var(--hero-draw-label)" text-anchor="middle">С/У</text>

        <!-- Dimension value labels -->
        <text x="210" y="10" font-size="4.5" font-family="'Inter', sans-serif" letter-spacing="0.08em" fill="var(--hero-draw-label)" text-anchor="middle">12 200</text>
        <text x="408" y="265" font-size="4.5" font-family="'Inter', sans-serif" letter-spacing="0.08em" fill="var(--hero-draw-label)" transform="rotate(90, 408, 265)">15 800</text>
      </svg>

      <!-- Depth layer: elevation fragment (bottom-right of panel) -->
      <svg
        class="hero-elevation"
        viewBox="0 0 180 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        style="position:absolute; right:-2%; bottom:0; width:44%; opacity: var(--hero-elev-opacity);"
      >
        <!-- Building elevation profile -->
        <polyline points="8,88 8,20 44,20 44,8 136,8 136,20 172,20 172,88 8,88" stroke="var(--hero-draw-stroke)" stroke-width="1.2"/>
        <!-- Floors -->
        <line x1="8" y1="54" x2="172" y2="54" stroke="var(--hero-draw-stroke-muted)" stroke-width="0.5"/>
        <!-- Windows elevation -->
        <rect x="18" y="28" width="18" height="20" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <rect x="50" y="28" width="18" height="20" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <rect x="18" y="62" width="18" height="20" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <rect x="50" y="62" width="18" height="20" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <rect x="100" y="16" width="28" height="32" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <rect x="140" y="28" width="18" height="20" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <rect x="140" y="62" width="18" height="20" stroke="var(--hero-draw-accent)" stroke-width="1"/>
        <!-- Ground line -->
        <line x1="0" y1="92" x2="180" y2="92" stroke="var(--hero-draw-stroke)" stroke-width="0.75"/>
        <!-- Label -->
        <text x="8" y="99" font-size="4.5" font-family="'Inter', sans-serif" letter-spacing="0.1em" fill="var(--hero-draw-label)">ФАСАД · ЮГ</text>
      </svg>

      <!-- Label chip: top-left corner mark -->
      <div class="hero-chip" style="position:absolute; top:0; left:0;">
        <span style="font-size:0.5rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:var(--hero-draw-label); opacity:0.7;">{siteConfig.shortName}</span>
      </div>

    </div>
    <!-- /hero-drawing -->

  </div>

  <!-- ── Content area ── z-index 20 ───────────────── -->
  <div class="hero-content container-site relative z-20 mt-auto pb-16 md:pb-24 pt-28 md:pt-32">

    <!-- Label: letter-spacing reveal -->
    <div class="hero-label mb-8 md:mb-10">
      <span
        class="text-[var(--color-fg-subtle)]"
        style="font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;"
      >
        {siteConfig.description}
      </span>
    </div>

    <!-- H1: each line reveals from different direction -->
    <div class="hero-heading-wrap" style="max-width: min(44rem, 58vw);" aria-label="Современный сайт для вашего бизнеса">
      <h1
        class="hero-title mb-6 md:mb-8"
        style="font-size: clamp(2.75rem, 6.5vw, 6rem); font-weight: 300; letter-spacing: -0.03em; line-height: 1.05; color: var(--color-fg);"
        aria-hidden="true"
      >
        <span class="hero-line-1 block overflow-hidden">
          <span class="hero-line-1-inner block">Современный сайт</span>
        </span>
        <span class="hero-line-2 block overflow-hidden">
          <span class="hero-line-2-inner block">для вашего</span>
        </span>
        <span class="hero-line-accent block overflow-hidden">
          <em class="hero-line-accent-inner not-italic block" style="color: var(--color-accent);">бизнеса</em>
        </span>
      </h1>
    </div>

    <!-- Subtitle -->
    <p
      class="hero-sub text-[var(--color-fg-muted)] text-base md:text-lg leading-relaxed mb-10 md:mb-12 max-w-md"
    >
      Быстрый, адаптивный и SEO-готовый шаблон на Astro<br class="hidden md:block" />
      для любого бизнес-сайта
    </p>

    <!-- CTA buttons -->
    <div class="hero-btns flex flex-col sm:flex-row gap-4">
      <Button href={siteConfig.cta.href} variant="primary" size="md">
        {siteConfig.cta.label}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="0" y1="7" x2="12" y2="7"/>
          <polyline points="8,3 12,7 8,11"/>
        </svg>
      </Button>
      <Button href="/items" variant="secondary" size="md">
        Смотреть кейсы
      </Button>
    </div>

    <!-- Stats -->
    <div class="hero-stats mt-14 md:mt-20 flex flex-wrap gap-x-10 gap-y-5 border-t border-[var(--hero-line)] pt-8">
      {[
        { value: '5+', label: 'лет опыта' },
        { value: '20+', label: 'проектов' },
        { value: '10', label: 'клиентов' },
        { value: '3', label: 'направления' },
      ].map((stat) => (
        <div class="flex flex-col gap-1">
          <p class="text-2xl font-light text-[var(--color-fg)] tracking-tight">{stat.value}</p>
          <p class="label-tag text-[var(--color-fg-muted)]">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 right-8 md:right-16 flex flex-col items-center gap-3 z-20"
    style="opacity: 0.3;"
    aria-hidden="true"
  >
    <span style="writing-mode: vertical-lr; letter-spacing: 0.15em; font-size: 0.52rem; font-weight: 500; text-transform: uppercase; color: var(--color-fg-subtle);">scroll</span>
    <div class="scroll-line w-px h-12" style="background: var(--hero-scroll);"></div>
  </div>
</section>

<style>
  /* iOS Safari safe viewport height */
  .hero-section {
    min-height: 100vh;   /* legacy browsers */
    min-height: 100svh;  /* iOS Safari 15.4+, Chrome 108+ */
  }

  /* ── Design tokens ──────────────────────────────── */
  .hero-section {
    --hero-panel-bg:          #f0ece4;
    --hero-line:              #cdc8c0;
    --hero-scroll:            #c8c4bc;

    /* SVG drawing tokens — light */
    --hero-draw-stroke:       rgba(90, 84, 76, 0.55);
    --hero-draw-stroke-muted: rgba(90, 84, 76, 0.28);
    --hero-draw-accent:       rgba(138, 118, 96, 0.70);
    --hero-draw-label:        rgba(90, 84, 76, 0.50);
    --hero-drawing-opacity:   0.85;
    --hero-elev-opacity:      0.60;
  }

  :global([data-theme="dark"]) .hero-section {
    --hero-panel-bg: #242118;
    --hero-line: #2e2c29;
    --hero-scroll: #4a4540;
    
    --hero-draw-stroke: rgba(240, 236, 228, 0.38);
    --hero-draw-stroke-muted: rgba(240, 236, 228, 0.18);
    --hero-draw-accent: rgba(200, 184, 152, 0.58);
    --hero-draw-label: rgba(240, 236, 228, 0.38);
    --hero-drawing-opacity: 0.72;
    --hero-elev-opacity: 0.45;
  }

  /* Dark-theme token overrides live in global.css — see comment there.
     Astro scoped styles compile [data-theme="dark"] as a sibling
     attribute on the component root, not as an ancestor selector,
     so they never match when data-theme is set on <html>. */

  /* ── Line-reveal animation ─────────────── */
  .hero-line-1-inner,
  .hero-line-2-inner,
  .hero-line-accent-inner {
    display: block;
    transform: translateY(110%);
    opacity: 0;
    will-change: transform, opacity;
    transition:
      transform 1s cubic-bezier(0.16, 1, 0.3, 1),
      opacity   0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-line-1-inner   { transition-delay: 0.45s; }
  .hero-line-2-inner   { transition-delay: 0.6s; }
  .hero-line-accent-inner { transition-delay: 0.75s; }

  /* Other hero elements */
  .hero-label,
  .hero-sub,
  .hero-btns,
  .hero-stats {
    opacity: 0;
    will-change: opacity, transform;
    transition:
      opacity   0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-label { transform: translateY(0.8rem); transition-delay: 0.25s; }
  .hero-sub   { transform: translateY(1rem);   transition-delay: 0.9s;  }
  .hero-btns  { transform: translateY(1rem);   transition-delay: 1.05s; }
  .hero-stats { transform: translateY(0);       transition-delay: 1.2s;  }

  /* Background elements */
  .hero-panel {
    opacity: 0;
    transform: translateX(3rem);
    transition:
      opacity   1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.05s,
      transform 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.05s;
  }
  .hero-vline {
    opacity: 0;
    transition: opacity 1.4s ease 0.1s;
  }
  .hero-hline {
    opacity: 0;
    transition: opacity 1.2s ease 0.3s;
  }
  .hero-drawing {
    opacity: 0;
    transform: translateY(1.2rem);
    transition:
      opacity   1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.55s,
      transform 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.55s;
  }
  .hero-plan {
    /* SVG path draw-on animation */
    stroke-dasharray: 1800;
    stroke-dashoffset: 1800;
    transition: stroke-dashoffset 2.4s cubic-bezier(0.4, 0, 0.2, 1) 0.8s;
  }
  .hero-elevation {
    opacity: 0;
    transition: opacity 1s ease 1.6s;
  }

  /* Revealed states */
  .hero-animate .hero-line-1-inner,
  .hero-animate .hero-line-2-inner,
  .hero-animate .hero-line-accent-inner {
    transform: translateY(0);
    opacity: 1;
  }
  .hero-animate .hero-label,
  .hero-animate .hero-sub,
  .hero-animate .hero-btns {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-animate .hero-stats   { opacity: 1; }
  .hero-animate .hero-panel   { opacity: 1; transform: translateX(0); }
  .hero-animate .hero-vline   { opacity: 0.55; }
  .hero-animate .hero-hline   { opacity: 1; }
  .hero-animate .hero-drawing { opacity: 1; transform: translateY(0); }
  .hero-animate .hero-plan    { stroke-dashoffset: 0; }
  .hero-animate .hero-elevation { opacity: 1; }

  /* Hide drawing on small screens — text is priority */
  @media (max-width: 767px) {
    .hero-drawing { display: none; }
    .hero-vline   { display: none; }
    .hero-hline   { display: none; }
  }

  /* Scroll line pulse */
  @keyframes pulse-line {
    0%, 100% { transform: scaleY(0.6); opacity: 0.3; }
    50%       { transform: scaleY(1);   opacity: 0.7; }
  }
  .scroll-line { animation: pulse-line 2.4s ease-in-out infinite; transform-origin: top; }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-line-1-inner, .hero-line-2-inner, .hero-line-accent-inner,
    .hero-label, .hero-sub, .hero-btns, .hero-stats,
    .hero-panel, .hero-vline, .hero-hline, .hero-drawing,
    .hero-elevation {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hero-plan {
      stroke-dashoffset: 0 !important;
      transition: none !important;
    }
    .scroll-line { animation: none; }
  }

  /* Hero buttons now use global .btn-* classes via Button.astro */
</style>

<script>
  function startHeroReveal() {
    const section = document.getElementById('hero');
    if (!section) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      section.classList.add('hero-animate');
      return;
    }

    // Small rAF delay so browser has painted the initial state
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        section.classList.add('hero-animate');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startHeroReveal);
  } else {
    startHeroReveal();
  }

  // Re-run after view transitions
  document.addEventListener('astro:page-load', startHeroReveal);
</script>
