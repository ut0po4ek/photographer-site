---
const advantages = [
  { title: 'Индивидуальный подход', desc: 'Каждый проект начинается с понимания ваших задач, целей и ожиданий от результата.' },
  { title: 'Полный цикл', desc: 'Сопровождаем проект от первой идеи до финального результата — без разрывов и потери контекста.' },
  { title: 'Внимание к деталям', desc: 'Детали создают впечатление. Мы уделяем им столько же внимания, что и общей концепции.' },
];
---

<section id="about" class="section-padding bg-[var(--color-bg)]">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <!-- Left: text -->
      <div>
        <span class="label-tag" data-reveal="left">О нас</span>
        <div class="divider my-4" data-reveal="clip" data-reveal-delay="150"></div>

        <h2
          class="mt-6 mb-8"
          style="font-size: clamp(1.75rem, 4vw, 3.25rem); font-weight: 300; letter-spacing: -0.025em;"
          data-reveal="up" data-reveal-delay="200"
        >
          Команда, которой<br />можно доверять
        </h2>

        <p class="text-[var(--color-fg-muted)] text-base leading-relaxed mb-6" data-reveal="up" data-reveal-delay="300">
          Мы решаем задачи клиентов с вниманием к деталям, срокам и конечному результату. Каждый проект — это партнёрство, а не просто выполнение заказа.
        </p>

        <p class="text-[var(--color-fg-muted)] text-base leading-relaxed" data-reveal="up" data-reveal-delay="400">
          Замените этот текст на описание вашей команды, опыта и подхода к работе.
        </p>
      </div>

      <!-- Right: advantages -->
      <div class="flex flex-col gap-8">
        {advantages.map((item, i) => (
          <div
            class="flex gap-6 pb-8 border-b border-[var(--color-border)]"
            data-reveal="right"
            data-reveal-delay={String(200 + i * 120)}
          >
            <span class="label-tag shrink-0 w-6 text-[var(--color-accent)]">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="text-sm font-medium mb-2 tracking-tight">{item.title}</h3>
              <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
