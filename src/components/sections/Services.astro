---
const services = [
  {
    number: '01',
    title: 'Консультация',
    description: 'Помогаем разобраться в задаче, выбрать подход и оценить объём работ.',
    features: ['Анализ задачи', 'Формат работы', 'Оценка сроков', 'Рекомендации'],
  },
  {
    number: '02',
    title: 'Разработка',
    description: 'Реализуем решение под ваши требования, сроки и бюджет.',
    features: ['Концепция', 'Реализация', 'Контроль качества', 'Документация'],
  },
  {
    number: '03',
    title: 'Сопровождение',
    description: 'Поддерживаем результат после запуска, оперативно решаем вопросы.',
    features: ['Поддержка', 'Доработки', 'Консультации', 'Развитие'],
  },
];
---

<section id="services" class="section-padding bg-[var(--color-bg)]">
  <div class="container-site">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14 md:mb-20">
      <div>
        <span class="label-tag reveal">Что мы делаем</span>
        <div class="divider my-4 reveal reveal-delay-1"></div>
        <h2 class="mt-6 reveal reveal-delay-2" style="font-size: clamp(1.5rem, 3.5vw, 2.75rem); font-weight: 300; letter-spacing: -0.02em;">
          Услуги
        </h2>
      </div>
      <p class="text-[var(--color-fg-muted)] text-sm max-w-xs leading-relaxed reveal reveal-delay-2">
        Замените этот текст на описание ваших услуг и их ценности для клиентов.
      </p>
    </div>

    <div class="flex flex-col divide-y divide-[var(--color-border)]">
      {services.map((service, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} group grid grid-cols-1 md:grid-cols-[4rem_1fr] gap-6 md:gap-12 py-10 md:py-12 transition-colors duration-300 hover:bg-[var(--color-bg-warm)] -mx-6 px-6 md:-mx-10 md:px-10`}
        >
          <div>
            <span class="label-tag text-[var(--color-accent)]">{service.number}</span>
          </div>

          <div>
            <h3 class="text-xl md:text-2xl font-light tracking-tight mb-3">{service.title}</h3>
            <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed mb-5 max-w-lg">{service.description}</p>
            <ul class="flex flex-wrap gap-2">
              {service.features.map((detail) => (
                <li class="text-xs text-[var(--color-fg-muted)] border border-[var(--color-border)] px-3 py-1 rounded-full">
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
