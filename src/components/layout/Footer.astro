---
import { siteConfig } from '../../config/site';
import Icon from '../ui/Icon.astro';
---

<footer style="background: #0d0d0d;">
  <div class="container-site py-12">

    <!-- Top row: brand + socials -->
    <div
      class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 pb-10 mb-8"
      style="border-bottom: 1px solid rgba(244,244,240,0.08);"
    >
      <div>
        <a
          href="/"
          class="block mb-2 text-sm font-medium tracking-[0.15em] uppercase"
          style="color: #f4f4f0;"
        >
          {siteConfig.name}
        </a>
        <p class="text-xs leading-relaxed max-w-xs" style="color: rgba(244,244,240,0.38);">
          {siteConfig.footer.tagline}
        </p>
      </div>

      <div class="flex gap-3">
        {siteConfig.contacts.telegram && <a href={siteConfig.contacts.telegram} class="footer-social-icon" target="_blank" rel="noreferrer" aria-label="Telegram"><Icon name="telegram" size={17} /></a>}
        {siteConfig.contacts.whatsapp && <a href={siteConfig.contacts.whatsapp} class="footer-social-icon" target="_blank" rel="noreferrer" aria-label="WhatsApp"><Icon name="whatsapp" size={17} /></a>}
        {siteConfig.contacts.instagram && <a href={siteConfig.contacts.instagram} class="footer-social-icon footer-ig-text" target="_blank" rel="noreferrer" aria-label="Instagram*">IG</a>}
        {siteConfig.contacts.max && <a href={siteConfig.contacts.max} class="footer-social-icon" target="_blank" rel="noreferrer" aria-label="Max"><Icon name="max" size={17} /></a>}
        {siteConfig.contacts.email && <a href={`mailto:${siteConfig.contacts.email}`} class="footer-social-icon" aria-label="Email"><Icon name="email" size={17} /></a>}
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
      <p class="text-xs" style="color: rgba(244,244,240,0.25);">
        © {siteConfig.year} {siteConfig.name}. Все права защищены.
      </p>
      <a
        href={siteConfig.footer.privacyHref}
        class="text-xs footer-link-bottom"
        style="color: rgba(244,244,240,0.25);"
      >
        Политика конфиденциальности
      </a>
    </div>

    <!-- Legal disclaimer -->
    <p class="text-[10px] leading-relaxed mt-6" style="color: rgba(244,244,240,0.28); max-width: 56ch;">
      *Instagram принадлежит компании Meta Platforms Inc., деятельность которой признана экстремистской и запрещена на территории РФ.
    </p>

  </div>
</footer>

<style>
  .footer-social-icon {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(244, 244, 240, 0.15);
    border-radius: 50%;
    color: rgba(244, 244, 240, 0.45);
    transition: border-color 200ms ease, color 200ms ease, background-color 200ms ease;
  }
  .footer-social-icon:hover {
    border-color: rgba(244, 244, 240, 0.55);
    color: #f4f4f0;
    background-color: rgba(244, 244, 240, 0.06);
  }
  .footer-ig-text {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }
  .footer-link-bottom {
    transition: color 200ms ease;
  }
  .footer-link-bottom:hover {
    color: rgba(244, 244, 240, 0.70) !important;
  }
</style>
