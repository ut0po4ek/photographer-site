---
import { siteConfig } from '../../config/site';
---

<footer style="background: #0d0d0d;">
  <div class="container-site py-12">

    <!-- Top row: brand + socials -->
    <div
      class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 pb-10 mb-8"
      style="border-bottom: 1px solid rgba(244,244,240,0.08);"
    >
      <div>
        <a
          href="/"
          class="block mb-2 text-sm font-medium tracking-[0.15em] uppercase"
          style="color: #f4f4f0;"
        >
          {siteConfig.name}
        </a>
        <p class="text-xs leading-relaxed max-w-xs" style="color: rgba(244,244,240,0.38);">
          {siteConfig.footer.tagline}
        </p>
      </div>

      <div class="flex gap-6" style="color: rgba(244,244,240,0.38);">
        <a href={siteConfig.contacts.telegram} class="footer-social text-xs tracking-widest uppercase" target="_blank" rel="noreferrer" aria-label="Telegram">TG</a>
        <a href={siteConfig.contacts.whatsapp} class="footer-social text-xs tracking-widest uppercase" target="_blank" rel="noreferrer" aria-label="WhatsApp">WA</a>
        <a href={siteConfig.contacts.instagram} class="footer-social text-xs tracking-widest uppercase" target="_blank" rel="noreferrer" aria-label="Instagram">IG</a>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
      <p class="text-xs" style="color: rgba(244,244,240,0.25);">
        © {siteConfig.year} {siteConfig.name}. Все права защищены.
      </p>
      <a
        href={siteConfig.footer.privacyHref}
        class="text-xs footer-social"
        style="color: rgba(244,244,240,0.25);"
      >
        Политика конфиденциальности
      </a>
    </div>

  </div>
</footer>

<style>
  .footer-social {
    transition: color 200ms ease;
  }
  .footer-social:hover {
    color: rgba(244, 244, 240, 0.70);
  }
</style>
